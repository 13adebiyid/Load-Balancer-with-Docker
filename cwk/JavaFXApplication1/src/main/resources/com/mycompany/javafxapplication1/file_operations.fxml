<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.javafxapplication1.FileOperationsController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="File Operations" />
        <GridPane alignment="CENTER" hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                <!-- Add a third column for sharing buttons -->
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            
            <!-- File Path Display -->
            <Label text="Selected File:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="fileTextField" editable="false" 
                      GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <!-- File Operation Buttons -->
            <Button fx:id="uploadBtn" text="Upload File" onAction="#uploadBtnHandler"
                    GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Button fx:id="downloadBtn" text="Download File" onAction="#downloadBtnHandler"
                    GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <!-- Progress Indicator -->
            <ProgressBar fx:id="progressBar" progress="0.0" 
                        GridPane.columnSpan="2" GridPane.rowIndex="2" />
            
            <!-- Back Button -->
            <Button fx:id="backBtn" text="Back to Main Menu" onAction="#backBtnHandler"
                    GridPane.columnSpan="2" GridPane.rowIndex="3" />
        </GridPane>
        
        <!-- Files Table with Context Menu -->
        <TableView fx:id="filesTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="fileNameColumn" text="File Name" />
                <TableColumn fx:id="ownerColumn" text="Owner" />
                <TableColumn fx:id="sizeColumn" text="Size" />
                <!-- Add new column for sharing status -->
                <TableColumn fx:id="sharedColumn" text="Shared" />
            </columns>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </TableView>
        
        <!-- Status Bar -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Current User:" />
            <Label fx:id="currentUserLabel" style="-fx-font-weight: bold;" />
            <Separator orientation="VERTICAL" />
            <Label text="Files Shared With Me:" />
            <Label fx:id="sharedFilesCountLabel" style="-fx-font-weight: bold;" />
        </HBox>
    </children>
</VBox>