<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.javafxapplication1.TerminalController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>
    
    <TextArea fx:id="outputArea" 
              editable="false" 
              wrapText="true" 
              VBox.vgrow="ALWAYS"
              style="-fx-font-family: 'monospace'; -fx-text-fill: white; -fx-control-inner-background: #2d2d2d;"/>
              
    <HBox spacing="5">
        <Label text=">" 
               style="-fx-font-family: 'monospace'; -fx-text-fill: #00ff00;"/>
        <TextField fx:id="commandInput" 
                   HBox.hgrow="ALWAYS"
                   style="-fx-font-family: 'monospace';"/>
    </HBox>
</VBox>